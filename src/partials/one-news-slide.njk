{% macro oneNewsSlide( pathDesktop, pathLaptop, pathTablet, pathMobile ) %}
<div class="one-news-slide">
	<picture class="one-news-slide__picture">
		<source srcset="{{pathMobile}}" media="(max-width: 650px)" />
		<source srcset="{{pathTablet}}" media="(max-width: 900px)" />
		<source srcset="{{pathLaptop}}" media="(max-width: 1100px)" />
		<img class="one-news-slide__img" src="{{ pathDesktop }}" alt="one news slide" />
	</picture>
	<h6 class="one-news-slide__title">Antrax IT - Italian factory for the production of radiators</h6>
	<p class="one-news-slide__text">01 January 2019</p>
</div>
{% endmacro %}
